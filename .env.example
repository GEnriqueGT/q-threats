# Neo4j. GET /api/graph devuelve solo datos desde Neo4j (sin grafo estático de reserva).
# Requiere NEO4J_URI, NEO4J_USER y NEO4J_PASSWORD para que /relations funcione.
#
# NEO4J_URI=neo4j+s://xxxx.databases.neo4j.io
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=
# NEO4J_DATABASE=neo4j

# Tope de aristas en la query por defecto. Vacío o 0 = sin LIMIT (grafo completo; cuidado con bases muy grandes).
# NEO4J_REL_LIMIT=5000

# Consulta personalizada sobre relaciones. Debe proyectar obligatoriamente source y target (nodos).
# Recomendado: rel (la relationship completa), p. ej. RETURN n AS source, m AS target, type(r) AS relType, r AS rel
# Alternativa si no proyectas rel: relType (string) y relProps (mapa de propiedades de la relación).
# Si usas NEO4J_REL_LIMIT > 0, incluye LIMIT toInteger($limit) o el parámetro que definas.
# NEO4J_CYPHER=

# Texto opcional del bloque de metadatos (la vista de grafo no muestra panel lateral).
# NEO4J_ACQUISITION_TITLE=
# NEO4J_ACQUISITION_SUMMARY=
# NEO4J_ACQUISITION_LINK=https://www.guatecompras.gt
# NEO4J_ACQUISITION_INSTITUTION=Q Threats
# NEO4J_ACQUISITION_AMOUNT=—
# NEO4J_ACQUISITION_DATE=Neo4j

# MiniMax (chat OpenAI-compatible). Solo servidor — usa .env.local, no subas la key al repo.
# MINIMAX_API_KEY=sk-api-YeZpdMKcRlefAquY5Og-8dE_YlmMrcaktf7vOjSfBKXmvjfmbTGx6PegvbJbSdZszKfn8MaTV8RSE9bDShXb-UJFo5SIZxTmfyaLZRF22-YTSBclgw1DJ14
# Opcional: por defecto https://api.minimax.io
# MINIMAX_BASE_URL=https://api.minimax.io
# Opcional: modelo (ver docs MiniMax)
# MINIMAX_MODEL=MiniMax-M2.7
