# =============================================================================
# Q Threats — plantilla de variables de entorno
# Copia este archivo a .env.local y rellena los valores. No commitees secretos.
# =============================================================================

# --- Neo4j (requerido para GET /api/graph y grafo “en vivo” en Relations) ---
# URI bolt o neo4j (Aura usa neo4j+s://...). No uses https:// en NEO4J_URL para Bolt.
NEO4J_URI=
NEO4J_USER=
# Alternativa al usuario:
# NEO4J_USERNAME=

NEO4J_PASSWORD=
# Alternativa:
# NEO4J_SECRET=

# Base de datos con nombre (Aura / Enterprise). Opcional.
# NEO4J_DATABASE=

# Tope de aristas leídas en la consulta por defecto (entero; vacío = sin límite en query).
# NEO4J_REL_LIMIT=

# Cypher personalizado para proyectar el grafo (avanzado).
# NEO4J_CYPHER=

# Metadatos del nodo “adquisición” sintético en la proyección JSON (todos opcionales).
# NEO4J_ACQUISITION_TITLE=
# NEO4J_ACQUISITION_SUMMARY=
# NEO4J_ACQUISITION_LINK=
# NEO4J_ACQUISITION_INSTITUTION=
# NEO4J_ACQUISITION_AMOUNT=
# NEO4J_ACQUISITION_DATE=

# --- Make.com (webhook para análisis legislativo: POST con { iniciativa_id }) ---
# Sin estos valores, GET /api/legislation/[id] responderá 503.
# MAKE_WEBHOOK_URL=
# MAKE_API_KEY=

# --- Supabase (GET /api/recent-reports → tabla law_risk_reports) ---
# SUPABASE_URL=
# Usa service role en servidor si necesitas ignorar RLS; si no, anon con políticas adecuadas.
# SUPABASE_SERVICE_ROLE_KEY=
# En algunos despliegues:
# SUPABASE_SECRET_KEY=
# SUPABASE_ANON_KEY=

# --- MiniMax (POST /api/chat) ---
# MINIMAX_API_KEY=
# Opcionales (valores por defecto en código si se omiten):
# MINIMAX_BASE_URL=https://api.minimax.io
# MINIMAX_MODEL=MiniMax-M2.7

# --- Servidor MCP local (mcp/server.ts con npm run mcp:stdio) ---
# URL del backend Next (local o producción). Por defecto: http://127.0.0.1:3000
# Q_THREATS_BACKEND_URL=
